{
	"$schema": "./node_modules/@biomejs/biome/configuration_schema.json",
	"vcs": {
		"enabled": false,
		"clientKind": "git",
		"useIgnoreFile": true
	},
	"files": {
		"ignoreUnknown": false,
		"includes": [
			"**",
			"!**/dist",
			"!**/.dist",
			"!**/.cache",
			"!**/.turbo",
			"!**/ui.css",
			"!node_modules",
			"!**/.tanstack",
			"!**/.typescript",
			"!**/routeTree.gen.ts"
		]
	},
	"formatter": {
		"enabled": true,
		"indentStyle": "tab"
	},
	"assist": {
		"actions": {
			"source": {
				"organizeImports": "on"
			}
		}
	},
	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true,
			"style": {
				"useNodejsImportProtocol": "off"
			},
			"correctness": {
				"useExhaustiveDependencies": "info"
			},
			"nursery": {
				"noFloatingPromises": "error",
				"useExhaustiveSwitchCases": "error"
			}
		}
	},
	"javascript": {
		"formatter": {
			"lineWidth": 95,
			"bracketSpacing": true,
			"quoteStyle": "double",
			"semicolons": "asNeeded",
			"trailingCommas": "none",
			"jsxQuoteStyle": "double",
			"arrowParentheses": "always"
		}
	}
}
