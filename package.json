		"clean": "turbo run clean && rm -rf .turbo node_modules"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.3.12",
		"@changesets/cli": "^2.29.8",
		"@turbo/gen": "^2.7.6",
		"turbo": "^2.7.6",
		"typescript": "^5.9.3"
	},
	"packageManager": "pnpm@10.0.0"
}
