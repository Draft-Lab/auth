{
	"name": "Draft Auth",
	"author": "Matheus Pergoli",
	"version": "0.1.0",
	"private": true,
	"scripts": {
		"dev": "turbo run dev",
		"changeset": "changeset",
		"build": "turbo run build",
		"version": "changeset version",
		"check": "biome check --write .",
		"format": "biome format --write .",
